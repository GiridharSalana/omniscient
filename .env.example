# ─────────────────────────────────────────────────────────────────
# Omniscient — Environment Variables
# Copy this to .env and fill in your API keys
# All services are FREE tier — no payment required
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=omniscient_secret

# ── AI Providers ──────────────────────────────────────────────────
# Cohere: https://cohere.com — 1,000 calls/month FREE
# Use for: Morning briefing (quality), sentiment classification
COHERE_API_KEY=

# Cerebras: https://cerebras.ai — Fast inference FREE tier
# Use for: Chat/QA (sub-second), emergency analysis
CEREBRAS_API_KEY=

# Google AI Studio: https://makersuite.google.com — 1,500 req/day FREE
# Use for: Overflow/fallback, code generation
GOOGLE_AI_API_KEY=

# ── Market Data ───────────────────────────────────────────────────
# Alpha Vantage: https://alphavantage.co — 25 calls/day FREE
ALPHA_VANTAGE_KEY=

# Finnhub: https://finnhub.io — 60 calls/minute FREE
FINNHUB_KEY=

# MarketAux: https://marketaux.com — 250 req/day FREE
MARKETAUX_KEY=

# FRED (St. Louis Fed): https://fred.stlouisfed.org — UNLIMITED FREE
FRED_API_KEY=

# ── Notifications (Optional) ──────────────────────────────────────
# Telegram Bot: https://t.me/botfather — FREE
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Config ────────────────────────────────────────────────────
# Timezone for scheduler and briefing (IANA format)
APP_TIMEZONE=Asia/Kolkata
# Morning briefing time (24h, local timezone)
BRIEFING_TIME=06:00
# Max price history to retain (days)
PRICE_HISTORY_DAYS=365
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
